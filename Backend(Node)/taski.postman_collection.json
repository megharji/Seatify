{
  "info": {
    "name": "Taski Ticket Booking API",
    "description": "Full API collection for the Taski take-home assessment backend. Run requests in order to follow the standard booking flow.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000/api", "type": "string" },
    { "key": "user_token", "value": "", "type": "string" },
    { "key": "admin_token", "value": "", "type": "string" },
    { "key": "event_id", "value": "", "type": "string" },
    { "key": "booking_id", "value": "", "type": "string" },
    { "key": "seat_ids", "value": "[]", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup (User)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/signup", "host": ["{{base_url}}"], "path": ["auth", "signup"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"user@example.com\",\n  \"password\": \"Password@123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.collectionVariables.set('user_token', res.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login (User)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Password@123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.collectionVariables.set('user_token', res.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login (Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"Admin@123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.collectionVariables.set('admin_token', res.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
            "url": { "raw": "{{base_url}}/auth/me", "host": ["{{base_url}}"], "path": ["auth", "me"] }
          }
        }
      ]
    },
    {
      "name": "Wallet",
      "item": [
        {
          "name": "Get Wallet + Transactions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
            "url": { "raw": "{{base_url}}/wallet", "host": ["{{base_url}}"], "path": ["wallet"] }
          }
        },
        {
          "name": "Add Money",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{user_token}}" },
              { "key": "Idempotency-Key", "value": "{{$randomUUID}}" }
            ],
            "url": { "raw": "{{base_url}}/wallet/add-money", "host": ["{{base_url}}"], "path": ["wallet", "add-money"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 5000,\n  \"note\": \"Initial top-up\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Events",
      "item": [
        {
          "name": "List Events",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/events", "host": ["{{base_url}}"], "path": ["events"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.length > 0) {",
                  "  pm.collectionVariables.set('event_id', res.data[0]._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "List Seats for Event",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/events/{{event_id}}/seats",
              "host": ["{{base_url}}"],
              "path": ["events", "{{event_id}}", "seats"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.seats) {",
                  "  const available = res.data.seats.filter(s => s.status === 'AVAILABLE').slice(0, 2).map(s => s._id);",
                  "  pm.collectionVariables.set('seat_ids', JSON.stringify(available));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Reserve Seats",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{user_token}}" },
              { "key": "Idempotency-Key", "value": "{{$randomUUID}}" }
            ],
            "url": { "raw": "{{base_url}}/bookings/reserve", "host": ["{{base_url}}"], "path": ["bookings", "reserve"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"{{event_id}}\",\n  \"seatIds\": {{seat_ids}}\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.booking) {",
                  "  pm.collectionVariables.set('booking_id', res.data.booking._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Confirm Booking",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{user_token}}" },
              { "key": "Idempotency-Key", "value": "{{$randomUUID}}" }
            ],
            "url": { "raw": "{{base_url}}/bookings/confirm", "host": ["{{base_url}}"], "path": ["bookings", "confirm"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingId\": \"{{booking_id}}\"\n}"
            }
          }
        },
        {
          "name": "My Bookings",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
            "url": { "raw": "{{base_url}}/bookings/my", "host": ["{{base_url}}"], "path": ["bookings", "my"] }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Create Event",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": { "raw": "{{base_url}}/admin/events", "host": ["{{base_url}}"], "path": ["admin", "events"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Rock Night 2026\",\n  \"description\": \"An epic live rock concert\",\n  \"venue\": \"Mumbai Arena\",\n  \"startsAt\": \"2026-06-15T19:00:00.000Z\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data._id) {",
                  "  pm.collectionVariables.set('event_id', res.data._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Update Event",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/admin/events/{{event_id}}",
              "host": ["{{base_url}}"],
              "path": ["admin", "events", "{{event_id}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Updated description\",\n  \"isActive\": true\n}"
            }
          }
        },
        {
          "name": "Delete Event",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": {
              "raw": "{{base_url}}/admin/events/{{event_id}}",
              "host": ["{{base_url}}"],
              "path": ["admin", "events", "{{event_id}}"]
            }
          }
        },
        {
          "name": "Bulk Create Seats",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/admin/events/{{event_id}}/seats/bulk",
              "host": ["{{base_url}}"],
              "path": ["admin", "events", "{{event_id}}", "seats", "bulk"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"seats\": [\n    { \"seatNumber\": \"A1\", \"price\": 500 },\n    { \"seatNumber\": \"A2\", \"price\": 500 },\n    { \"seatNumber\": \"B1\", \"price\": 750 },\n    { \"seatNumber\": \"B2\", \"price\": 750 }\n  ]\n}"
            }
          }
        },
        {
          "name": "List Seats for Event (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": {
              "raw": "{{base_url}}/admin/events/{{event_id}}/seats",
              "host": ["{{base_url}}"],
              "path": ["admin", "events", "{{event_id}}", "seats"]
            }
          }
        },
        {
          "name": "List All Bookings",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": {
              "raw": "{{base_url}}/admin/bookings",
              "host": ["{{base_url}}"],
              "path": ["admin", "bookings"],
              "query": [
                { "key": "status", "value": "CONFIRMED", "disabled": true },
                { "key": "eventId", "value": "{{event_id}}", "disabled": true },
                { "key": "userId", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "List All Transactions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": {
              "raw": "{{base_url}}/admin/transactions",
              "host": ["{{base_url}}"],
              "path": ["admin", "transactions"]
            }
          }
        },
        {
          "name": "Cancel Booking (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Idempotency-Key", "value": "{{$randomUUID}}" }
            ],
            "url": { "raw": "{{base_url}}/admin/bookings/cancel", "host": ["{{base_url}}"], "path": ["admin", "bookings", "cancel"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingId\": \"{{booking_id}}\"\n}"
            }
          }
        }
      ]
    }
  ]
}
